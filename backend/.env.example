# Copy to backend/.env.local and fill in real values.
# .env.local is gitignored.

# --- OpenAI reply agent (for /api/messages/ingest auto-replies) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Reacher (TikTok shop intelligence) ---
REACHER_API_KEY=your_reacher_api_key_here

# Single shop_id (integer as string). The per-product creators/videos
# endpoints do NOT accept "all" or comma-separated lists — only the
# trending-videos endpoint does. Per-request override is also supported via
# the `shop_id` query/body param on each endpoint.
REACHER_SHOP_ID=your_shop_id_here

# --- Overshoot ---
OVERSHOOT_API_KEY=ovs_your_overshoot_key_here

# --- Browser Use (cloud agent for live scraping) ---
BROWSER_USE_API_KEY=bu_your_browser_use_key_here

# Per-platform profile IDs. Each social_pulse scraper picks up the matching
# env var (or pass --profile-id at the CLI). If unset, falls back to the
# shared "social" Browser-Use profile (which only works for sites you've
# logged into via `uv run python social_login.py`).
BROWSER_USE_TIKTOK_PROFILE_ID=
BROWSER_USE_TWITTER_PROFILE_ID=
BROWSER_USE_REDDIT_PROFILE_ID=
BROWSER_USE_LINKEDIN_PROFILE_ID=

# --- Campaign orchestrator ---
# Bumped from the older default of 6. Reacher returns up to 100 per call;
# 30 keeps the response readable while feeding enough creators into the
# DM automation step.
CAMPAIGN_CREATORS_PER_PRODUCT=30

# --- Outreach automations (see automations.py) ---
# Master switch. Default: false. When false, /api/marketing-campaign still
# builds the planned automation payload and returns it under `automations`,
# but does NOT call Reacher's create endpoint.
AUTOMATIONS_ENABLED=false

# Secondary safety. Default: true. Even when AUTOMATIONS_ENABLED=true, the
# create POST is skipped and we just log the payload. Flip to false only
# once you've reviewed a dry-run payload and want to actually send.
AUTOMATIONS_DRY_RUN=true

# --- Notion (creator-script publisher; optional) ---
# Setup (one-time):
#   1. Create an internal integration at https://www.notion.so/my-integrations
#   2. Copy the "Internal Integration Token" into NOTION_API_KEY below.
#   3. Open the target Scripts page in Notion -> "..." -> "Add connections"
#      -> select your integration. Without this step, every API call 404s.
#   4. The page ID is the 32-hex suffix in the page URL
#      (e.g. https://www.notion.so/Scripts-35b2e5a1e6d480c0b3dffd9f5c67bfd8
#       -> 35b2e5a1e6d480c0b3dffd9f5c67bfd8). Dashed or undashed both work.
NOTION_API_KEY=
NOTION_SCRIPTS_PAGE_ID=35b2e5a1e6d480c0b3dffd9f5c67bfd8

# --- Tensorlake → Photon social-pulse loop ---
# Authenticates the loop's POSTs to /api/social-pulse/tick.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
TENSORLAKE_WEBHOOK_SECRET=
# Optional default iMessage recipient for the markdown summary.
TENSORLAKE_PULSE_RECIPIENT=
# Public URL the sandbox can reach (ngrok forwarding URL while local).
BACKEND_URL=
# Loop config — read by backend/tensorlake_app/launch_loop.py at start time.
PULSE_TOPIC=openai
PULSE_TOP_N=3
PULSE_RECIPIENT=
