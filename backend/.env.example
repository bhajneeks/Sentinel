# Copy to backend/.env and fill in real values.
# .env is gitignored.

REACHER_API_KEY=your_reacher_api_key_here

# Single shop_id (integer as string). The per-product creators/videos
# endpoints do NOT accept "all" or comma-separated lists — only the
# trending-videos endpoint does.
REACHER_SHOP_ID=your_shop_id_here
