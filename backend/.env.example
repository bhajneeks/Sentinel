# Copy to backend/.env.local and fill in real values.
# .env.local is gitignored.

# --- OpenAI reply agent (for /api/messages/ingest auto-replies) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Reacher (TikTok shop intelligence) ---
REACHER_API_KEY=your_reacher_api_key_here

# Single shop_id (integer as string). The per-product creators/videos
# endpoints do NOT accept "all" or comma-separated lists — only the
# trending-videos endpoint does. Per-request override is also supported via
# the `shop_id` query/body param on each endpoint.
REACHER_SHOP_ID=your_shop_id_here

# --- Campaign orchestrator ---
# Bumped from the older default of 6. Reacher returns up to 100 per call;
# 30 keeps the response readable while feeding enough creators into the
# DM automation step.
CAMPAIGN_CREATORS_PER_PRODUCT=30

# --- Outreach automations (see automations.py) ---
# Master switch. Default: false. When false, /api/marketing-campaign still
# builds the planned automation payload and returns it under `automations`,
# but does NOT call Reacher's create endpoint.
AUTOMATIONS_ENABLED=false

# Secondary safety. Default: true. Even when AUTOMATIONS_ENABLED=true, the
# create POST is skipped and we just log the payload. Flip to false only
# once you've reviewed a dry-run payload and want to actually send.
AUTOMATIONS_DRY_RUN=true
